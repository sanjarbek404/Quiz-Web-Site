{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz definition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "timeLimit": { "type": "number", "description": "Time limit in minutes" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "description", "category", "difficulty", "timeLimit", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "description": "A question within a quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "question": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "correctAnswer": { "type": "string" }
      },
      "required": ["id", "quizId", "question", "options", "correctAnswer"]
    },
    "Result": {
      "title": "Result",
      "description": "A user's quiz attempt result",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "quizId": { "type": "string" },
        "score": { "type": "number" },
        "percentage": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["id", "userId", "quizId", "score", "percentage", "completedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "Quizzes available in the platform"
    },
    "/questions/{questionId}": {
      "schema": { "$ref": "#/entities/Question" },
      "description": "Questions for quizzes"
    },
    "/results/{resultId}": {
      "schema": { "$ref": "#/entities/Result" },
      "description": "User quiz results"
    }
  }
}
